PORT=3000
HOST=0.0.0.0

# Profile Maker API service. Put the real company billing API key only in .env.
PROFILE_API_PORT=3100
GEMINI_API_KEY=
# Generate at least 32 random characters and use the same value in both PM2 processes.
PROFILE_AUTH_SECRET=
FRONTEND_ORIGIN=
PROFILE_TRUST_PROXY=loopback
PROFILE_RATE_LIMIT_WINDOW_MS=600000
PROFILE_RATE_LIMIT_MAX=10
GEMINI_MAX_QUEUE_DEPTH=5
DAILY_PROFILE_LIMIT=20
DAILY_IMAGE_LIMIT=20
MAX_DOCUMENT_TEXT_CHARS=5000
MAX_IMAGE_CONTEXT_CHARS=500
MAX_TEXT_OUTPUT_TOKENS=1600
GEMINI_MIN_REQUEST_INTERVAL_MS=30000
ENABLE_AI_IMAGES=true
TEXT_MODEL=gemini-2.5-flash-lite
IMAGE_MODEL=gemini-2.5-flash-image

# Existing HongCafe admin login page.
LEGACY_LOGIN_URL=https://hongcafe.peoplev.co.kr/admin

# Set this if the login form posts to a different URL.
LEGACY_LOGIN_POST_URL=https://hongcafe.peoplev.co.kr/api/admin/loginadmin

# Update these after checking the login request in browser DevTools.
LEGACY_USERNAME_FIELD=admin_id
LEGACY_PASSWORD_FIELD=password

# Optional: JSON object for extra form fields required by the legacy login form.
LEGACY_EXTRA_FIELDS={}

# Optional: use one or both after checking actual success/failure responses.
LEGACY_SUCCESS_TEXT=
LEGACY_FAILURE_TEXT=

# Local development only. Do not enable on the real server.
AUTH_BYPASS=false

# Enable only when the service is behind HTTPS.
COOKIE_SECURE=false
